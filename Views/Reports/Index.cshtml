@{
    ViewData["Title"] = "Отчёты";
    Layout = "~/Views/Shared/_Layout.cshtml";
    dynamic report1 = ViewBag.Report1;
    dynamic report2 = ViewBag.Report2;
    dynamic report3 = ViewBag.Report3;
}

<h1>Отчёты</h1>

<div class="row mb-5">
    <div class="col-12">
        <h2 class="mt-4 mb-3">Раздел 1: Полный список преподавателей</h2>
        <p class="text-muted">Все преподаватели с указанием кафедры, отсортированные по имени</p>
        
        @{
            var list1 = (System.Collections.IEnumerable)ViewBag.Report1;
            int count1 = 0;
            foreach (var item in list1) { count1++; }
        }
        
        @if (count1 == 0)
        {
            <div class="alert alert-info">Нет данных</div>
        }
        else
        {
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Имя преподавателя</th>
                        <th>Кафедра</th>
                        <th>Публикации</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.Report1)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.DepartmentName</td>
                            <td class="text-center">@item.Publications</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="row mb-5">
    <div class="col-12">
        <h2 class="mt-4 mb-3">Раздел 2: Количество преподавателей по кафедрам</h2>
        <p class="text-muted">Группировка с подсчётом количества</p>
        
        @{
            var list2 = (System.Collections.IEnumerable)ViewBag.Report2;
            int count2 = 0;
            foreach (var item in list2) { count2++; }
        }
        
        @if (count2 == 0)
        {
            <div class="alert alert-info">Нет данных</div>
        }
        else
        {
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Кафедра</th>
                        <th class="text-center">Количество преподавателей</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.Report2)
                    {
                        <tr>
                            <td>@item.Department</td>
                            <td class="text-center">@item.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="row">
    <div class="col-12">
        <h2 class="mt-4 mb-3">Раздел 3: Среднее количество публикаций по кафедрам</h2>
        <p class="text-muted">Группировка с вычислением среднего значения, отсортировано по убыванию</p>
        
        @{
            var list3 = (System.Collections.IEnumerable)ViewBag.Report3;
            int count3 = 0;
            foreach (var item in list3) { count3++; }
        }
        
        @if (count3 == 0)
        {
            <div class="alert alert-info">Нет данных</div>
        }
        else
        {
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Кафедра</th>
                        <th class="text-center">Среднее количество публикаций</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ViewBag.Report3)
                    {
                        <tr>
                            <td>@item.Department</td>
                            <td class="text-center">@item.AvgPublications.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
