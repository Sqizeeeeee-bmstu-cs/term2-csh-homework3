@model List<homework3.Models.Department>
@{
    ViewData["Title"] = "Кафедры";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Кафедры</h1>

<div class="mb-3">
    <a class="btn btn-success" href="@Url.Action("Create")">+ Добавить кафедру</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        Нет данных. <a href="@Url.Action("Create")">Добавьте первую кафедру</a>.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Название</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var department in Model)
            {
                <tr>
                    <td>@department.Id</td>
                    <td>@department.Name</td>
                    <td>
                        <a class="btn btn-sm btn-primary" href="@Url.Action("Edit", new { id = department.Id })">Редакт.</a>
                        <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", new { id = department.Id })">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
