@model homework3.Models.Professor
@{
    ViewData["Title"] = "Редактировать преподавателя";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Редактировать преподавателя</h1>

<form asp-action="Edit" method="post" class="col-md-6">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label">Имя:</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="DepartmentId" class="form-label">Кафедра:</label>
        <select asp-for="DepartmentId" class="form-select">
            <option value="">-- Выберите кафедру --</option>
            @foreach (var dept in ViewBag.Departments)
            {
                <option value="@dept.Id" selected="@(dept.Id == Model.DepartmentId)">@dept.Name</option>
            }
        </select>
        <span asp-validation-for="DepartmentId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Publications" class="form-label">Количество публикаций:</label>
        <input asp-for="Publications" type="number" class="form-control" min="0" />
        <span asp-validation-for="Publications" class="text-danger"></span>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Сохранить изменения</button>
        <a class="btn btn-secondary" href="@Url.Action("Index")">Отмена</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
