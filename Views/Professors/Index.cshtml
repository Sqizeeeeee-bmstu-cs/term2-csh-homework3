@model List<homework3.Models.Professor>
@{
    ViewData["Title"] = "Преподаватели";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Преподаватели</h1>

<div class="mb-3">
    <a class="btn btn-success" href="@Url.Action("Create")">+ Добавить преподавателя</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        Нет данных. <a href="@Url.Action("Create")">Добавьте первого преподавателя</a>.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Имя</th>
                <th>Кафедра</th>
                <th>Публикации</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var professor in Model)
            {
                <tr>
                    <td>@professor.Id</td>
                    <td>@professor.Name</td>
                    <td>@professor.Department?.Name</td>
                    <td>@professor.Publications</td>
                    <td>
                        <a class="btn btn-sm btn-primary" href="@Url.Action("Edit", new { id = professor.Id })">Редакт.</a>
                        <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", new { id = professor.Id })">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
